# Required. Vitality Console URL for S3 auth (s3-credentials + cache + SigV4). No other auth mode.
VITALITY_CONSOLE_URL=http://localhost:8000

# Required. Must match Vitality Console's WARPDRIVE_SERVICE_SECRET.
WARPDRIVE_SERVICE_SECRET=your_shared_secret

# Optional. TTL in seconds for credential cache (default 300).
# S3_AUTH_CACHE_TTL_SECS=300
